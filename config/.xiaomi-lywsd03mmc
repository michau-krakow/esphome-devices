esp32_ble_tracker:

binary_sensor:
  - platform: ble_presence
    id: ble_presence_${xiaomi_name}
    name: Xiaomi ${xiaomi_friendly_name}
    mac_address: ${xiaomi_mac_${xiaomi_name}}

sensor:
  - platform: ble_rssi
    id: ble_rssi_${xiaomi_name}
    name: Xiaomi ${xiaomi_friendly_name} RSSI
    mac_address: ${xiaomi_mac_${xiaomi_name}}

  - platform: xiaomi_lywsd03mmc
    id: xiaomi_lywsd03mmc_${xiaomi_name}
    mac_address: ${xiaomi_mac_${xiaomi_name}}
    bindkey: ${xiaomi_key_${xiaomi_name}}
    temperature:
      icon: mdi:thermometer-bluetooth
      name: Xiaomi ${xiaomi_friendly_name} Temperature
      id: xiaomi_temperature_${xiaomi_name}
    humidity:
      icon: mdi:water-percent
      name: Xiaomi ${xiaomi_friendly_name} Humidity
      id: xiaomi_humidity_${xiaomi_name}
    battery_level:
      icon: mdi:battery-bluetooth-variant
      name: Xiaomi ${xiaomi_friendly_name} Battery
      id: xiaomi_battery_${xiaomi_name}
